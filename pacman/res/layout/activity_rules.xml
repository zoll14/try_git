<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_black">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="HOW TO PLAY"
        android:textColor="@color/pacman_yellow"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/maze_blue"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp" />

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fadeScrollbars="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Goal -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GOAL"
                android:textColor="@color/pacman_yellow"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Eat every dot in the maze to complete the level and advance. Clear all levels to keep climbing the high-score table."
                android:textColor="@color/score_white"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="20dp" />

            <!-- Dots & Pellets -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="COLLECTIBLES"
                android:textColor="@color/pacman_yellow"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Small dot  .......  10 pts\nPower pellet  ....  50 pts"
                android:textColor="@color/dot_white"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The 4 large flashing dots in the corners are Power Pellets. Eating one turns all ghosts blue for 8 seconds — chase them down for bonus points!"
                android:textColor="@color/score_white"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="20dp" />

            <!-- Ghosts -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GHOSTS"
                android:textColor="@color/pacman_yellow"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Blinky (red)"
                android:textColor="@color/ghost_blinky"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The relentless one. Locks onto Pac-Man and chases directly."
                android:textColor="@color/score_white"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pinky (pink)"
                android:textColor="@color/ghost_pinky"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The ambusher. Targets 4 tiles ahead of where Pac-Man is heading."
                android:textColor="@color/score_white"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Inky (cyan)"
                android:textColor="@color/ghost_inky"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The wildcard. Uses Blinky&#8217;s position and Pac-Man&#8217;s direction to pick an unpredictable angle."
                android:textColor="@color/score_white"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Clyde (orange)"
                android:textColor="@color/ghost_clyde"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The shy one. Chases when far away, but retreats to his corner when he gets too close."
                android:textColor="@color/score_white"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="20dp" />

            <!-- Ghost scoring -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EATING GHOSTS"
                android:textColor="@color/pacman_yellow"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1st ghost  ......  200 pts\n2nd ghost  ......  400 pts\n3rd ghost  ......  800 pts\n4th ghost  ......  1600 pts"
                android:textColor="@color/ghost_frightened"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The score doubles for each ghost eaten within a single Power Pellet. The counter resets when the next pellet is eaten. Ghosts flash white just before they recover — act fast!"
                android:textColor="@color/score_white"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="20dp" />

            <!-- Tunnel -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TUNNEL"
                android:textColor="@color/pacman_yellow"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The side passages wrap around the screen. Use them to lose a ghost on your tail — ghosts slow down inside the tunnel."
                android:textColor="@color/score_white"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="20dp" />

            <!-- Lives -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LIVES"
                android:textColor="@color/pacman_yellow"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="You start with 3 lives. A life is lost whenever a non-blue ghost catches Pac-Man. The game ends when all lives are gone."
                android:textColor="@color/score_white"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Back button -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/maze_blue"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp" />

    <Button
        android:id="@+id/btn_rules_back"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="BACK"
        android:textColor="@color/pacman_yellow"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:background="@color/background_black"
        android:layout_margin="16dp" />

</LinearLayout>
